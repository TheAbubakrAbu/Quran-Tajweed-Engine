      "wordCount": 4,
      "letterCount": 14
    },
    {
      "id": 2,
      "textArabic": "مَلِكِ ٱلنَّاسِ",
      "textTransliteration": "Maliki alnnasi",
      "textEnglishSaheeh": "The Sovereign of mankind.",
      "textEnglishMustafa": "the Master of humankind,",
      "juz": 30,
      "page": 604,
      "wordCount": 2,
      "letterCount": 8
    },
    {
      "id": 3,
      "textArabic": "إِلَٰهِ ٱلنَّاسِ",
      "textTransliteration": "Ilahi alnnasi",
      "textEnglishSaheeh": "The God of mankind,",
      "textEnglishMustafa": "the God of humankind,",
      "juz": 30,
      "page": 604,
      "wordCount": 2,
      "letterCount": 8
    },
    {
      "id": 4,
      "textArabic": "مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ",
      "textTransliteration": "Min sharri alwaswasi alkhannasi",
      "textEnglishSaheeh": "From the evil of the retreating whisperer -",
      "textEnglishMustafa": "from the evil of the lurking whisperer—",
      "juz": 30,
      "page": 604,
      "wordCount": 4,
      "letterCount": 17
    },
    {
      "id": 5,
      "textArabic": "ٱلَّذِي يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ",
      "textTransliteration": "Allathee yuwaswisu fee sudoori alnnasi",
      "textEnglishSaheeh": "Who whispers [evil] into the breasts of mankind -",
      "textEnglishMustafa": "who whispers into the hearts of humankind—",
      "juz": 30,
      "page": 604,
      "wordCount": 5,
      "letterCount": 20
    },
    {
